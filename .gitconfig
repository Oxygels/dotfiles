# This is Git's per-user configuration file.
[user]
    name = Oxygels
    email = 39919597+Oxygels@users.noreply.github.com

[credential]
    helper = cache --timeout=3600

[pull]
    rebase = true

[alias]
    l = log --graph --oneline
    a = add
    d = diff
    ds = diff --staged
    dl = diff @~
    s = status
    st = stash
    sp = stash pop
    sl = stash list
    c = commit
    ck = checkout
    cm = commit -m
    p = pull
    pu = push
    pt = push --tag
    rmc = rm --cached
    t = tag --sort v:refname # -v:refname to invert the sort
    ap = apply --3way

# Remove local branches not existing on remote
# WARNING: Make sure you always create your branches (usually from issues) on Github
[remote "origin"]
    prune = true
