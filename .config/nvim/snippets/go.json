{
  "Error check": {
    "prefix": "ie",
    "body": [
      "if err != nil {",
      "\tlog.Panicln(err)",
      "}"
    ],
    "description": "if err != nil check"
  },
  "Error wrap": {
    "prefix": "iew",
    "body": [
      "if err != nil {",
      "\treturn fmt.Errorf(\"${1:context}: %w\", err)",
      "}"
    ],
    "description": "if err != nil, wrapped"
  }
}
